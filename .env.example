# Shared hotspot settings
HOTSPOT_NAME=Programmable Hotspot
HOTSPOT_SSID=⚡Netra-Guest
HOTSPOT_LISTING_ID=local-hotspot
HOTSPOT_LOCATION=San Francisco, CA
HOST_HANDLE=local-host
RATE_PER_MIN=0.001
HOTSPOT_DOWN=100
HOTSPOT_UP=50
HOTSPOT_SIGNAL=4

# Solana
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_WALLET=
# Optional override for the refund signer used on early disconnects.
# Leave blank on devnet to use the built-in Netra demo treasury.
# Format: JSON array exported from a Solana wallet secret key.
SOLANA_REFUND_SECRET_KEY=

# Optional trusted HTTPS checkout origin for same-phone Phantom mobile flows.
# Example:
#   SECURE_PORTAL_ORIGIN=https://pay.netra.xyz
# If that hostname is remote/public instead of DNS-trapped locally, also set:
#   EXTRA_PREPAY_ALLOW_HOSTS=pay.netra.xyz
SECURE_PORTAL_ORIGIN=https://captive.apple.com
EXTRA_PREPAY_ALLOW_HOSTS=

# Optional x402 demo client
# JSON array exported from a Solana devnet wallet secret key
SOLANA_SECRET_KEY=

# Filecoin / Synapse
FILECOIN_NETWORK=calibration
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_PRIVATE_KEY=
FILECOIN_WITH_CDN=false
FILECOIN_SOURCE=netra
